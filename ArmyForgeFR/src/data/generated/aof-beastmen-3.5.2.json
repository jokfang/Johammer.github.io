{
  "sourcePdf": "ArmyForgeFR/Bibliotheque/AOF - Beastmen 3.5.2.pdf",
  "systemCode": "AOF",
  "systemName": "Age of Fantasy",
  "armyName": "Beastmen",
  "version": "3.5.2",
  "introduction": "Beastmen are a coalition of different species of bestial\nhumanoids, which rely on ambush tactics to overwhelm their\nenemies.\nOver the centuries, the Beastmen lived together in the southern\nsavannah of Tyria, building great cities and trading prosperously.\nThe opening of the Rift destroyed many of their cities, and\nDaemons drove them from their home. Most of the Beastmen\nhave fled north, surviving by raiding and scavenging while they\nseek a new home.",
  "backgroundStory": "The vast savannah in southern Tyria had been inhabited by\nwildlife since the beginning of time. At the center of the largest\nwatering hole of the land, a giant lush tree provided shade and\nfood, and from its roots a magical substance seeped into its fruit.\nOver many generations, the animals that ate the fruit of this tree\nslowly changed and became sentient, and came to see the tree as\nsacred, settling around it in peace.\nGradually, the different tribes of Ndoli, Waheni, Hapari, Ndwari,\nKemba, and Silombi learned to co-exist and formed a\nconfederacy of closely knit tribes. The Beastmen built a great\ncivilization in the savannah, constructing a great capital city\naround the Holy Tree, and a network of smaller cities around,\nwhich expanded out through the grasslands and connected the\nwatering holes around it. For centuries, the Beastmen tribes lived\nlives of peace and prosperity on the Savannah.\nThen, the Rift opened. It tore through the Savannah, damaging\nthe Holy Tree and destroying many of their cities. When the\nDaemons began to emerge, most Beastmen were forced to\nabandon their homeland. The only thing that remains of their old\ncivilization are the ruins of their cities, and the dried out remains\nof the Holy Tree, whose once crystalline waters have now turned\nblack.\nSome Beastmen still call these ruins their home, but there is no\nhope that it will flourish once again in the future. Others have\nbegun to wander along the edge of the Rift, towards the heart of\nTyria. In order to survive, they raid settlements and burn forests\nto build equipment and camps. Each amongst the Beastmen has\ntheir own reason for this great migration. Some hope to find a\nnew home, while others seek to understand the cause of the rift.\nThere are others who have become accustomed to raiding and\nviolence, and take any opportunity to destroy the homes of\nothers, just as their own homes were destroyed.\nHow will you guide your tribe?",
  "armyWideSpecialRule": [
    {
      "name": "Bestial",
      "description": "When attacking, targets must re-roll unmodified Defense results of 6 when blocking hits from this model's weapons."
    }
  ],
  "specialRules": [
    {
      "name": "Bestial Boost",
      "description": "If this model has Bestial, enemies taking hits from it must re-roll successful unmodified defense results of 5-6 from Bestial (instead of only on 6)."
    },
    {
      "name": "Casting Debuff",
      "description": "Once per activation, before attacking, pick one enemy unit within 18\" with Caster, which gets -1 to casting rolls once (next time the effect would apply)."
    },
    {
      "name": "Crush",
      "description": "When it's this model's turn to attack in melee, roll X dice. For each 6+ the target takes one hit with AP(2)."
    },
    {
      "name": "Melee Evasion",
      "description": "Enemies get -1 to hit rolls in melee when attacking units where all models have this rule."
    },
    {
      "name": "Melee Slayer",
      "description": "This model's melee weapons get AP(+2) against units where most models have Tough(3) or higher."
    },
    {
      "name": "Mind Control",
      "description": "Once per activation, before attacking, pick one enemy unit within 18\", which must take a morale test. If failed you may move it by up to 6\" in a straight line in any direction."
    },
    {
      "name": "Morale Debuff",
      "description": "Once per activation, before attacking, pick one enemy unit within 18\", which gets -1 to morale test rolls once (next time the effect would apply)."
    },
    {
      "name": "Piercing Assault",
      "description": "This model gets AP(+1) when charging."
    },
    {
      "name": "Precision Tag",
      "description": "Once per game, during this model's activation, pick one enemy unit within 36\" and in line of sight of it, and place X markers on it. When attacking, friendly units may remove markers from their target before rolling to hit to get +Y to hit rolls, where Y is the number of removed markers."
    },
    {
      "name": "Repel Ambushers",
      "description": "Enemy units using Ambush must be set up over 12\" away from this model's unit."
    },
    {
      "name": "Resistance",
      "description": "When a unit where all models have this rule takes wounds, roll one die for each. On a 6+ it is ignored. If the wounds were from a spell, then they are ignored on a 2+ instead."
    },
    {
      "name": "Shred",
      "description": "On unmodified results of 1 to block hits, this weapon deals 1 extra wound."
    },
    {
      "name": "Surge",
      "description": "On unmodified results of 6 to hit, this weapon deals 1 extra hits (only the original hit counts as a 6 for special rules)."
    },
    {
      "name": "Tear",
      "description": "Against units where most models have Tough(3) to Tough(9), this weapon gets AP(+4)."
    },
    {
      "name": "Unpredictable Fighter",
      "description": "When in melee, roll one die and apply one effect to all models with this rule: on a 1-3 they get AP(+1), and on a 4-6 they get +1 to hit rolls instead."
    }
  ],
  "auraSpecialRules": [
    {
      "name": "Ambush Aura",
      "description": "This model and its unit get Ambush."
    },
    {
      "name": "Bestial Boost Aura",
      "description": "This model and its unit get Bestial Boost."
    },
    {
      "name": "Furious Aura",
      "description": "This model and its unit get Furious."
    },
    {
      "name": "Melee Evasion Aura",
      "description": "This model and its unit get Melee Evasion."
    },
    {
      "name": "Piercing Assault Aura",
      "description": "This model and its unit get Piercing Assault."
    },
    {
      "name": "Precision Shooter Aura",
      "description": "This model and its unit get +1 to hit rolls when shooting."
    }
  ],
  "armySpells": [
    {
      "name": "Surge of Power",
      "cost": 1,
      "description": "Pick one friendly unit within 12\", which gets Bestial Boost once (next time the effect would apply)."
    },
    {
      "name": "Flock Attack",
      "cost": 1,
      "description": "Pick one enemy unit within 12\", which takes 2 hits with AP(1) and Surge. Roll as many dice as hits to see if \"on rolls of 6\" effects trigger."
    },
    {
      "name": "Hunting Roar",
      "cost": 2,
      "description": "Pick up to two enemy units within 18\", which get -1 to morale test rolls once (next time the effect would apply)."
    },
    {
      "name": "Ancestral Wrath",
      "cost": 2,
      "description": "Pick one enemy model within 24\", which takes 2 hits with Tear."
    },
    {
      "name": "Spirit Mantle",
      "cost": 3,
      "description": "Pick up to three friendly units within 12\", which get Regeneration once (next time the effect would apply)."
    },
    {
      "name": "Destructive Flame",
      "cost": 3,
      "description": "Pick one enemy unit within 12\", which takes 9 hits."
    }
  ],
