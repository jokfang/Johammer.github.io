<!-- Xml UI. See documentation: https://api.tabletopsimulator.com/ui/introUI/ -->
<Panel id="main-panel" width="500" height="300" color="rgba(0, 0, 0, 0.8)" padding="30"
  fontSize="20" allowDragging="true" returnToOriginalPositionWhenReleased="false">
  <Panel>
    <Button height="30" width="30" color="rgba(255, 0, 0, 0.8)" position="380 120"
      onClick="onCloseInput">
      <Text fontSize="16" fontStyle="bold" color="rgba(255, 255, 255, 1)">X</Text>
    </Button>
  </Panel>
  <Panel>
    <Text alignment="center" position="70 50" width="400" fontSize="16" fontStyle="bold"
      color="rgba(255, 255, 255, 1)">
      Colle ici ton lien OPR AF → TTS et clic sur Générer
    </Text>

  </Panel>
  <Panel>
    <InputField
      position="-55 0"
      padding="10"
      width="490"
      id="opr-af-to-tts-share-link"
      lineType="SingleLine"
      preferredHeight="10"
      onValueChanged="onTextInputChange"
      placeholder="https://opr-af-to-tts.netlify.app/.netlify/functions/save-list?listId=123"
    />
  </Panel>
  <Panel>
    <Button position="-160 -100" height="50" onClick="onSubmit">Générer</Button>
  </Panel>


</Panel>